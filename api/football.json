export default async function handler(req, res) {
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'GET, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');
 
  if (req.method === 'OPTIONS') return res.status(200).end();
 
  const apiKey = process.env.APIFOOTBALL_KEY;
  if (!apiKey) {
    console.error('[football.json] APIFOOTBALL_KEY env var is not set!');
    return res.status(500).json({ error: 'API key not configured' });
  }
 
  try {
    const params    = { ...req.query };
    const endpoint  = params.endpoint || 'fixtures';
    delete params.endpoint;
 
    const queryString = Object.keys(params).length
      ? '?' + new URLSearchParams(params).toString()
      : '';
 
    const url = `https://v3.football.api-sports.io/${endpoint}${queryString}`;
    console.log('[football.json] Calling:', url);
 
    const response = await fetch(url, {
      headers: {
        'x-apisports-key': apiKey,
      },
    });
 
    // Log rate limit headers so we can see usage in Vercel logs
    const remaining = response.headers.get('x-ratelimit-requests-remaining');
    const limit     = response.headers.get('x-ratelimit-requests-limit');
    if (remaining !== null) {
      console.log(`[football.json] API quota: ${remaining}/${limit} remaining`);
      if (parseInt(remaining) < 10) {
        console.warn('[football.json] ⚠️ API quota nearly exhausted!');
      }
    }
 
    if (response.status === 429) {
      console.error('[football.json] Rate limit exceeded (429)');
      return res.status(429).json({ error: 'Rate limit exceeded', remaining: 0 });
    }
 
    if (!response.ok) {
      console.error('[football.json] API returned', response.status);
      return res.status(response.status).json({ error: `API error ${response.status}` });
    }
 
    const data = await response.json();
 
    // Log any API-level errors returned in the response body
    if (data.errors && Object.keys(data.errors).length > 0) {
      console.error('[football.json] API body errors:', JSON.stringify(data.errors));
    }
 
    return res.status(200).json(data);
 
  } catch (err) {
    console.error('[football.json] Handler error:', err.message);
    return res.status(500).json({ error: 'Football API error', detail: err.message });
  }
}
 
