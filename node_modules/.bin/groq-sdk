#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/Pitchside/node_modules/.pnpm/groq-sdk@1.1.2/node_modules/groq-sdk/node_modules:/home/ubuntu/Pitchside/node_modules/.pnpm/groq-sdk@1.1.2/node_modules:/home/ubuntu/Pitchside/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/Pitchside/node_modules/.pnpm/groq-sdk@1.1.2/node_modules/groq-sdk/node_modules:/home/ubuntu/Pitchside/node_modules/.pnpm/groq-sdk@1.1.2/node_modules:/home/ubuntu/Pitchside/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../.pnpm/groq-sdk@1.1.2/node_modules/groq-sdk/bin/cli" "$@"
else
  exec node  "$basedir/../.pnpm/groq-sdk@1.1.2/node_modules/groq-sdk/bin/cli" "$@"
fi
